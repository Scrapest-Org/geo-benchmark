{
  "name": "@scrapest/twitter-scraper",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "concurrently": "^9.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "scripts": {
    "push": "bun --env-file=.env --filter @scrapest/web-push start",
    "app": "bun --env-file=.env --filter @scrapest/app dev",
    "all": "concurrently \"bun run push\" \"bun run app\"",
    "test": "bun test",
    "format": "bun x prettier --write .",
    "script": "bun run scripts/$1.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:app": "tsc --noEmit -p tsconfig.app-check.json"
  },
  "trustedDependencies": [
    "sharp"
  ],
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "bullmq": "^5.70.4"
  }
}
