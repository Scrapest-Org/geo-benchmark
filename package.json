{
  "name": "@scrapest/twitter-scraper",
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "concurrently": "^9.2.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "private": true,
  "scripts": {
    "push": "bun --env-file=.env --filter @scrapest/web-push start",
    "poll": "bun --env-file=.env --filter @scrapest/web-poll start",
    "app": "bun --env-file=.env --filter @scrapest/app dev",
    "discord": "bun --env-file=.env --filter @scrapest/discord dev",
    "telegram": "bun --env-file=.env --env-file=apps/telegram/.env --filter @scrapest/telegram dev",
    "dashboard": "bun --env-file=.env --filter @scrapest/dashboard dev",
    "tg-app": "concurrently \"bun run app\" \"bun run telegram\"",
    "fcm": "bun --env-file=.env --filter @scrapest/fcm-push start",
    "all": "concurrently \"bun run poll\" \"bun run push\" \"bun run app\"",
    "apps": "concurrently \"bun run dashboard\" \"bun run app\"",
    "test": "bun test",
    "format": "bun x prettier --write .",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "script": "bun run scripts/$1.ts"
  },
  "trustedDependencies": [
    "sharp"
  ],
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "bullmq": "^5.70.4"
  }
}
