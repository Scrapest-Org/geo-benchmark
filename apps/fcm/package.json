{
  "name": "@scrapest/fcm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript port of chrome-fcm — Chrome FCM web-push receiver for Twitter",
  "bin": {
    "@scrapest/fcm": "./src/index.ts"
  },
  "scripts": {
    "proto:gen": "mkdir -p gen && protoc --plugin=protoc-gen-ts_proto=../../node_modules/.bin/protoc-gen-ts_proto.exe --ts_proto_out=gen --ts_proto_opt=esModuleInterop=true,outputServices=false,useOptionals=all,useExactTypes=false,forceLong=string,initializeFieldsAsUndefined=true --proto_path=./proto ./proto/checkin.proto ./proto/mcs.proto && bun scripts/patch-proto-encoders.ts",
    "build": "bun run proto:gen",
    "start": "bun run src/index.ts",
    "test": "bun test"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "commander": "^12.1.0",
    "protobufjs": "^7.4.0",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "ts-proto": "^2.4.2",
    "typescript": "^5.6.0"
  }
}
