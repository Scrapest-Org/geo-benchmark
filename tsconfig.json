{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@scrapest/config": ["packages/config/index.ts"],
      "@scrapest/config/*": ["packages/config/*"],
      "@scrapest/constants": ["packages/constants/index.ts"],
      "@scrapest/constants/*": ["packages/constants/*"],
      "@scrapest/core": ["packages/core/app/index.ts"],
      "@scrapest/core/*": ["packages/core/*"],
      "@scrapest/fcm-client": ["packages/fcm-client/src/index.ts"],
      "@scrapest/fcm-client/*": ["packages/fcm-client/src/*"],
      "@scrapest/axios": ["packages/axios/index.ts"],
      "@scrapest/axios/*": ["packages/axios/*"],
      "@scrapest/tcp-rpc": ["packages/tcp-rpc/index.ts"],
      "@scrapest/tcp-rpc/*": ["packages/tcp-rpc/*"]
    },
    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}
