      "default": "./utils/encrypt-decrypt.ts"
    },
    "./utils/console": {
      "bun": "./utils/console.ts",
      "import": "./utils/console.ts",
      "default": "./utils/console.ts"
    },
    "./oauth1": {
      "bun": "./oauth1.ts",
