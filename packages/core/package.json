{
  "name": "@scrapest/core",
  "version": "1.0.0",
  "main": "./app/index.ts",
  "types": "./app/index.ts",
  "dependencies": {
    "@scrapest/config": "workspace:*",
    "@scrapest/constants": "workspace:*",
    "@scrapest/axios": "workspace:*",
    "linkedom": "^0.18.12",
    "otpauth": "^9.4.1",
    "node-telegram-bot-api": "^0.67.0",
    "lru-cache": "^11.3.5"
  },
  "exports": {
